				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
				<Linker>
					<Add library="OpenglSoftware/libglu32.a" />
					<Add library="OpenglSoftware/libglut32.a" />
					<Add library="OpenglSoftware/libopengl32.a" />
					<Add library="winmm" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/FarmWorld" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
		</Compiler>
